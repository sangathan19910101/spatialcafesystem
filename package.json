{
  "name": "spatial-cafe-system",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "backend:dev": "cd backend && bash -c 'source .venv/bin/activate && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000'",
    "dev:all": "concurrently \"npm run backend:dev\" \"npm run dev\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
